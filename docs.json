{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Lynx",
  "colors": {
    "primary": "#334CFF",
    "light": "#537EFC",
    "dark": "#313494"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navigation": {
    "languages": [
      {
        "language": "en",
        "default": true,
        "navbar": {
          "links": [
            {
              "label": "Support",
              "href": "mailto:partners@hvnn.me"
            }
          ],
          "primary": {
            "type": "button",
            "label": "Dashboard",
            "href": "https://app.lynx.dev"
          }
        },
        "groups": [
          {
            "group": "Get started",
            "pages": ["index", "sdk/quickstart", "sdk/configuration"]
          },
          {
            "group": "Use the SDK",
            "pages": [
              "sdk/tracing",
              "sdk/instrumentation",
              "sdk/guardrails",
              "sdk/delivery"
            ]
          },
          {
            "group": "Reference",
            "pages": ["sdk/api-reference"]
          }
        ]
      },
      {
        "language": "ko",
        "navbar": {
          "links": [
            {
              "label": "지원",
              "href": "mailto:partners@hvnn.me"
            }
          ],
          "primary": {
            "type": "button",
            "label": "대시보드",
            "href": "https://app.lynxops.co"
          }
        },
        "groups": [
          {
            "group": "시작하기",
            "pages": ["ko/index", "ko/sdk/quickstart", "ko/sdk/configuration"]
          },
          {
            "group": "SDK 사용하기",
            "pages": [
              "ko/sdk/tracing",
              "ko/sdk/instrumentation",
              "ko/sdk/guardrails",
              "ko/sdk/delivery"
            ]
          },
          {
            "group": "레퍼런스",
            "pages": ["ko/sdk/api-reference"]
          }
        ]
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/hvnn-oss"
    }
  }
}
